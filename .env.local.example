# Copy this file to .env.local and fill in the values.
# Use the exact "Transaction pooler" URI from Supabase > Connect.
# For Vercel serverless functions, transaction mode on port 6543 is the correct choice.
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:6543/postgres

# Session signing secret (32+ chars recommended)
JWT_SECRET=replace-this-with-a-long-random-secret
