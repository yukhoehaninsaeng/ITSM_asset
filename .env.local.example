# ──────────────────────────────────────────────────────────
# 이 파일을 복사하여 .env.local 로 저장하고 값을 채워주세요.
# .env.local 은 .gitignore 에 포함되어 있어 GitHub에 올라가지 않습니다.
# ──────────────────────────────────────────────────────────

# Supabase → Settings → Database → Transaction pooler 연결 문자열
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# 랜덤 비밀 문자열 (아무 긴 문자열이나 ok)
JWT_SECRET=여기에-랜덤한-긴-문자열을-넣으세요-최소-32자

# ──────────────────────────────────────────────────────────
# Vercel 환경변수 대시보드에도 동일하게 설정해야 합니다:
#   DATABASE_URL
#   JWT_SECRET
# ──────────────────────────────────────────────────────────
